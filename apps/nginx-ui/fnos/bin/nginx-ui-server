#!/bin/sh
APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR=$1

APP_INI="${APP_DATA_DIR}/app.ini"

# --- Bundled nginx paths (shipped inside this app) ---
NGINX_BIN="${APP_DIR}/sbin/nginx"
NGINX_CONF="${APP_DATA_DIR}/nginx.conf"
NGINX_LOG_DIR="${APP_DATA_DIR}/logs"
NGINX_PID="${APP_DATA_DIR}/nginx.pid"
NGINX_TEMP_DIR="${APP_DATA_DIR}/tmp"

# --- Ensure directory structure ---
mkdir -p "$NGINX_LOG_DIR"
mkdir -p "$NGINX_TEMP_DIR"

for dir in sites-available sites-enabled conf.d streams-available streams-enabled; do
    mkdir -p "${APP_DATA_DIR}/${dir}"
done

# --- Generate default nginx.conf if not exists ---
if [ ! -f "$NGINX_CONF" ]; then
    cat > "$NGINX_CONF" << CONF
worker_processes auto;
pid ${NGINX_PID};
error_log ${NGINX_LOG_DIR}/error.log;

events {
    worker_connections 1024;
}

http {
    include       ${APP_DIR}/conf/mime.types;
    default_type  application/octet-stream;

    access_log ${NGINX_LOG_DIR}/access.log;

    sendfile        on;
    keepalive_timeout  65;

    client_body_temp_path ${NGINX_TEMP_DIR}/client_body;
    proxy_temp_path       ${NGINX_TEMP_DIR}/proxy;
    fastcgi_temp_path     ${NGINX_TEMP_DIR}/fastcgi;
    uwsgi_temp_path       ${NGINX_TEMP_DIR}/uwsgi;
    scgi_temp_path        ${NGINX_TEMP_DIR}/scgi;

    include ${APP_DATA_DIR}/sites-enabled/*;
    include ${APP_DATA_DIR}/conf.d/*.conf;
}

stream {
    include ${APP_DATA_DIR}/streams-enabled/*;
}
CONF
fi

# --- Generate default app.ini for nginx-ui if not exists ---
if [ ! -f "$APP_INI" ]; then
    cat > "$APP_INI" << INI
[server]
Host     = 0.0.0.0
Port     = ${TRIM_SERVICE_PORT}
RunMode  = release

[nginx]
AccessLogPath = ${NGINX_LOG_DIR}/access.log
ErrorLogPath  = ${NGINX_LOG_DIR}/error.log
ConfigDir     = ${APP_DATA_DIR}
ConfigPath    = ${NGINX_CONF}
SbinPath      = ${NGINX_BIN}
PIDPath       = ${NGINX_PID}
TestConfigCmd = ${NGINX_BIN} -t -c ${NGINX_CONF}
ReloadCmd     = ${NGINX_BIN} -c ${NGINX_CONF} -s reload
RestartCmd    = ${NGINX_BIN} -c ${NGINX_CONF} -s reload

[node]
Name = fnOS
INI
fi

# --- Always ensure critical nginx paths point to bundled binary ---
# (handles upgrades where app install path may have changed)
if [ -f "$APP_INI" ]; then
    sed -i "s|^SbinPath[[:space:]]*=.*|SbinPath        = ${NGINX_BIN}|" "$APP_INI"
    sed -i "s|^ConfigPath[[:space:]]*=.*|ConfigPath      = ${NGINX_CONF}|" "$APP_INI"
    sed -i "s|^PIDPath[[:space:]]*=.*|PIDPath         = ${NGINX_PID}|" "$APP_INI"
    sed -i "s|^TestConfigCmd[[:space:]]*=.*|TestConfigCmd   = ${NGINX_BIN} -t -c ${NGINX_CONF}|" "$APP_INI"
    sed -i "s|^ReloadCmd[[:space:]]*=.*|ReloadCmd       = ${NGINX_BIN} -c ${NGINX_CONF} -s reload|" "$APP_INI"
    sed -i "s|^RestartCmd[[:space:]]*=.*|RestartCmd      = ${NGINX_BIN} -c ${NGINX_CONF} -s reload|" "$APP_INI"
fi

# Ensure nginx lib path is available
export LD_LIBRARY_PATH=${APP_DIR}/lib:${LD_LIBRARY_PATH:-}
export PATH=${APP_DIR}/sbin:$PATH

# --- Start bundled nginx daemon ---
"$NGINX_BIN" -c "$NGINX_CONF" -e "$NGINX_LOG_DIR/error.log"

# --- Start nginx-ui (foreground, PID tracked by fnOS) ---
cd "$APP_DIR" || exit 1
exec ./nginx-ui --config "$APP_INI"

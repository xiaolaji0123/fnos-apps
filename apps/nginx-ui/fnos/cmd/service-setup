#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.log"
PID_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.pid"

APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR="${TRIM_PKGVAR}"

SERVICE_COMMAND="$APP_DIR/bin/nginx-ui-server $APP_DATA_DIR"
SVC_BACKGROUND=y
SVC_WRITE_PID=y

service_preuninst() {
    # 终止 nginx-ui 进程
    # 使用 -x 精确匹配进程名，避免误杀 appcenter-cli 等包含 "nginx-ui" 参数的进程
    pkill -x "nginx-ui" 2>/dev/null || true
    sleep 1
    pkill -9 -x "nginx-ui" 2>/dev/null || true

    # 终止内置 nginx 进程（匹配应用数据目录，避免误杀独立 Nginx 应用或系统 nginx）
    pkill -f "nginx.*${TRIM_PKGVAR}" 2>/dev/null || true
    sleep 1
    pkill -9 -f "nginx.*${TRIM_PKGVAR}" 2>/dev/null || true
}

service_poststop() {
    service_preuninst
}
